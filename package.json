{
  "name": "news",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "PORT=3000 nuxt dev",
    "dev-mobile": "PORT=80 nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:report": "vitest run --reporter=html && npx vite preview --outDir html",
    "test:coverage": "vitest run --coverage && npx vite preview --outDir coverage"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "nuxt": "^4.4.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610",
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "vitest": "^4.1.0"
  }
}
